{
  "name": "pattern-editor",
  "productName": "Pattern Editor",
  "version": "0.1.0",
  "description": "Dispense program pattern editor",
  "main": ".vite/build/index.js",
  "scripts": {
    "prestart": "tsc --noEmit -p tsconfig.src.json",
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "dist:portable": "electron-forge package && electron-builder --win portable --prepackaged \"out/Pattern Editor-win32-x64\"",
    "dist:zip": "electron-forge package && powershell -Command \"Compress-Archive -Force -Path 'out/Pattern Editor-win32-x64/*' -DestinationPath 'dist/PatternEditor-0.1.0-win-x64.zip'\"",
    "lint": "eslint --ext .ts,.tsx .",
    "test": "vitest run && tsc --noEmit -p tsconfig.src.json",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.src.json"
  },
  "build": {
    "appId": "com.patterneditor.app",
    "productName": "Pattern Editor",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [{ "target": "portable", "arch": ["x64"] }],
      "icon": "MYE.ico"
    },
    "portable": {
      "artifactName": "PatternEditor-${version}-portable.exe"
    }
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.4.0",
    "@electron-forge/maker-deb": "^7.4.0",
    "@electron-forge/maker-rpm": "^7.4.0",
    "@electron-forge/maker-squirrel": "^7.4.0",
    "@electron-forge/maker-zip": "^7.4.0",
    "@electron-forge/plugin-auto-unpack-natives": "^7.4.0",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.4.0",
    "@electron/fuses": "^1.8.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "electron": "^31.0.0",
    "electron-builder": "^26.8.1",
    "electron-reload": "^2.0.0-alpha.1",
    "eslint": "^8.57.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "~5.4.5",
    "vite": "^5.3.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "clipper2-ts": "^2.0.1-15",
    "electron-squirrel-startup": "^1.0.1",
    "electron-store": "^7.0.3",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "zustand": "^4.5.0"
  }
}
